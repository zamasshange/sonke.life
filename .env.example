# Rename this file to .env.local and place it next to package.json (project root).
# Next.js does NOT load env files from app/public or other subfolders.

# Preferred provider (Google Gemini)
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Currency conversion provider (https://freecurrencyapi.com/)
FREECURRENCY_API_KEY=
